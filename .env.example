# Server port
PORT=5000

# Master password (absolute access from environment variable)
MASTERKEY=supersecret

# Named admin passwords
# Format: username:password:Full Name,username2:password2:Full Name 2
# Example: john:MySecurePass1:John Doe,jane:AnotherPass2:Jane Smith
ADMINS=admin1:MySecurePass1:Admin One,admin2:AnotherPass2:Admin Two
